#!/usr/bin/env bash
# cortex-hermes — Sprint 4.7 backward-compat shim.
#
# Renamed to cortex-steward in Sprint 4.7. Forwards every invocation to the
# new entrypoint and emits a one-line deprecation warning. Removed in v0.2.0.
#
# Set STEWARD_SUPPRESS_DEPRECATION=1 to silence the warning.

set -e

if [ "${STEWARD_SUPPRESS_DEPRECATION:-}" != "1" ]; then
  echo "[steward:deprecation] cortex-hermes was renamed to cortex-steward in Sprint 4.7. This shim is removed in v0.2.0 — please update your scripts/cron." >&2
fi

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
exec "$SCRIPT_DIR/cortex-steward" "$@"
