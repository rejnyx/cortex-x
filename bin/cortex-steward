#!/usr/bin/env bash
# cortex-steward — bash shim for the Steward runtime CLI
# (renamed from cortex-hermes in Sprint 4.7).
#
# Resolves the cortex-x source directory via two strategies:
#   1) Repo-local: if SCRIPT_DIR/cortex-steward.cjs exists, use it directly
#      (developer mode — running from a cortex-x clone).
#   2) Installed: read $HOME/.claude/shared/cortex-source.yaml to find
#      cortex_source, then delegate to $cortex_source/bin/cortex-steward.cjs.
#
# The two-strategy design keeps cortex-x source as the single source of truth
# (no drift between $HOME/.claude/shared/bin/ and the repo's bin/steward/).
# Shim is small + stable; the implementation can evolve in the source repo
# without re-running install.sh.

set -e

if ! command -v node > /dev/null 2>&1; then
  echo "ERROR: node is required but not found on PATH." >&2
  echo "  cortex-x's hooks and Steward runtime both require Node 22+." >&2
  exit 1
fi

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Strategy 1: repo-local
if [ -f "$SCRIPT_DIR/cortex-steward.cjs" ] && [ -d "$SCRIPT_DIR/steward" ]; then
  exec node "$SCRIPT_DIR/cortex-steward.cjs" "$@"
fi

# Strategy 2: installed shim — read cortex-source.yaml
SOURCE_YAML="$HOME/.claude/shared/cortex-source.yaml"
if [ ! -f "$SOURCE_YAML" ]; then
  echo "ERROR: cortex-x not installed (missing $SOURCE_YAML)." >&2
  echo "  Run install.sh first, or invoke from a cortex-x clone." >&2
  exit 1
fi

# Flat-yaml parse — cortex_source: <path>. Strip CR (Windows), drop quotes.
CORTEX_SOURCE="$(grep -E '^cortex_source:[[:space:]]*' "$SOURCE_YAML" \
  | sed -E 's/^cortex_source:[[:space:]]*//' \
  | tr -d '\r' \
  | sed -E 's/^"//; s/"$//')"

if [ -z "$CORTEX_SOURCE" ]; then
  echo "ERROR: cortex_source: missing in $SOURCE_YAML." >&2
  exit 1
fi

STEWARD_ENTRY="$CORTEX_SOURCE/bin/cortex-steward.cjs"
if [ ! -f "$STEWARD_ENTRY" ]; then
  echo "ERROR: $STEWARD_ENTRY not found." >&2
  echo "  Re-run install.sh, or fix cortex_source: in $SOURCE_YAML." >&2
  exit 1
fi

exec node "$STEWARD_ENTRY" "$@"
