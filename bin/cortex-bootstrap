#!/usr/bin/env bash
# cortex-bootstrap — thin shell shim that invokes the Node implementation
# at bin/cortex-bootstrap.cjs (which has the real arrow-key TUI).
#
# Why a Node implementation? cortex-x already requires Node for hooks (.cjs),
# so this is a zero-additional-dep change. The Node script gives us a
# modern arrow-key + Enter UX matching @clack/prompts / @inquirer/prompts
# without requiring `npm install`.

set -e

if ! command -v node > /dev/null 2>&1; then
  echo "ERROR: node is required but not found on PATH." >&2
  echo "  cortex-x's hooks and bootstrap UI both require Node 18+." >&2
  echo "  Install Node first, then re-run." >&2
  exit 1
fi

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
exec node "$SCRIPT_DIR/cortex-bootstrap.cjs" "$@"
