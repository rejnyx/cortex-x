# Dependencies
node_modules/
# cortex-x intentionally does NOT commit a lockfile (single dev dep `c8`,
# no runtime deps). `npm install` regenerates it locally. Surfaced by the
# Sprint 1.6.11 dogfood: untracked package-lock.json was tripping Hermes
# pre-flight DIRTY_TREE check on a fresh clone + npm install.
package-lock.json
yarn.lock
pnpm-lock.yaml

# Build output
dist/
build/
.turbo/

# Test artifacts
coverage/
.nyc_output/
.tap/
tmp/
.test-tmp/
# Sprint 2.3a foundation: mutation testing artifacts. Stryker writes to
# reports/ (mutation HTML dashboard, .stryker-tmp/ sandbox). Sprint 2.3b's
# `mutation_score_drift` action_kind only commits reports/mutation.json
# (the snapshot used for drift detection across PRs); everything else in
# reports/ is per-run scratch and must not land in commits.
reports/
!reports/mutation.json
.stryker-tmp/
stryker-incremental.json

# Hermes runtime data when CORTEX_DATA_HOME points inside the workspace.
# GitHub Actions workflows set CORTEX_DATA_HOME=$GITHUB_WORKSPACE/.cortex-data
# so the journal artifact upload step can reach it. Without this rule the
# dry-run step writes .cortex-data/journal/<slug>/<date>.jsonl which then
# trips the execute step's halt-check (DIRTY_TREE).
.cortex-data/
# Per-fixture transient git state — fixtures themselves are git-tracked,
# but synthetic git histories (created by stage fixture builders) get a
# .git/ inside them at test time and should never be committed.
tests/fixtures/**/.git/
tests/fixtures/**/node_modules/
# Synthetic stage-fixture transient state — generated by fixture-utils.cjs
# at test runtime, regenerated idempotently each run.
tests/fixtures/**/.cortex-stage-seed
tests/fixtures/**/.cortex-stage-ledger

# Environment
.env
.env.local
.env*.local

# Maintainer scratch notes inside templates/ (e.g. transcribed video notes).
# Real templates are .hbs / .md / .json — .txt in templates/ is always personal.
templates/*.txt

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/

# Logs
*.log
npm-debug.log*
yarn-debug.log*

# Runtime
.claude/compact-state.md
.claude/sessions/
.claude/shell-snapshots/

# Personal data (ship-ready — see standards/ship-ready.md)
# Project entries, dated insights, journal streams, project-scoped research
# caches are maintainer-private. Framework-level examples ship.
/projects/*.md
!/projects/README.md
!/projects/cortex-x.md
# insights/proposals/* are framework examples (whole subdir ships).
# Top-level dated insights are the user's private mining outputs — ignored.
/insights/20*-*.md
/insights/rejected/
/insights/META-*.md
# journal is per-machine — never shipped.
/journal/20*.jsonl
/journal/.hook-errors.log
# research: framework-level decision caches ship (manual `git add`).
# Project-specific caches are private.
/research/*-20*.md
!/research/README.md
!/research/tone-adaptation-*.md
!/research/beta-distribution-*.md
# runtime & per-user overrides
/.hook-errors.log
module.local.yaml
.claude/
config/ship-ready-denylist.local.txt

# Maintainer redactor map — real-name → placeholder map used by
# scripts/sync-to-public.mjs. The sync script itself ships; the rule data
# (which by definition contains real PII) MUST NOT. Use *.example.json
# for shipped templates.
/scripts/sanitize-rules.json
/scripts/sanitize-rules.*.json
!/scripts/sanitize-rules.example.json
/scripts/*-private.json
# Regression-target list (real local project paths) — gitignored. Example
# scaffold (regression-targets.example.json) ships; the .local.json doesn't.
/scripts/regression-targets.local.json

# Temp review artifacts (diff files, lock files from prior sessions)
*.diff
.tmp-*
*.tmp
*.bak
*.backup
*.orig
*.tsbuildinfo

# Editor swap / autosave / local history
*.swp
*.swo
*~
.history/

# OS extras (preempted — none currently in repo)
.AppleDouble/
__MACOSX/
.Spotlight-V100
.Trashes
Desktop.ini
$RECYCLE.BIN/

# Credentials — pre-emptive. cortex-x doesn't ship any of these today; rule
# blocks accidental commit when an operator generates a key locally.
*.pem
*.key
*.crt
*.p12
*.pfx
*.cer
.ssh/
id_rsa
id_ed25519

# Local cortex-data alias when CORTEX_DATA_HOME points inside the workspace
# without the explicit `.cortex-data/` prefix (defensive — main rule above
# is `.cortex-data/`, this catches the `./.cortex/` shorthand some users try)
/.cortex/

# Python (rare — only if operator uses py tooling locally for filter-repo etc.)
venv/
.venv/
__pycache__/
*.pyc
.python-version

# Framework build/cache dirs (none currently used by cortex-x; pre-emptive
# for retrofit scenarios where users adopt cortex-x in repos that already
# have these)
.next/
.nuxt/
.svelte-kit/
.serverless/
.parcel-cache/
.tool-versions
.nvmrc

# Local PII purge / history-rewrite safety branches/tags
pre-pii-purge-*

# Internal design docs referencing maintainer's private projects — not shipped
/docs/framework-rfc.md
# Maintainer interview prep / job-search docs — never shipped, never tracked.
# Pattern matches sanitize-rules.json fileExclusions for "docs/pohovor-*.md".
/docs/pohovor-*.md

# Dogfood archives — by definition contain audit findings about PRIVATE third-
# party repos (colleague's company, employer's stack, etc.). Going public would
# leak security findings + tech-debt evidence. Generate locally, review, NEVER
# commit. Sprint 2.10.7 cleanup: removed pre-existing docs/dogfood/* archive
# and added this rule to prevent recurrence.
/docs/dogfood/
.last-capability-tip

# === Sprint 2.17.x repo-hygiene audit (2026-05-13) ===
# Operator's source-material transcripts — personal research drops, not framework docs.
# docs/transcripts/README.md ships as the convention pointer; data files are personal.
/docs/transcripts/*.txt
/docs/transcripts/*.md
!/docs/transcripts/README.md

# Internal working docs — kept locally, never committed. Marketing copy and
# dogfood-process planning are operator-facing scratchpads, not framework docs.
/docs/launch-copy.md
/docs/steward-dogfood-plan.md

# Operator's hand-curated architecture diagrams — personal mental-model captures,
# not referenced from README or shipped docs.
/docs/pics/

# Dated implementation briefs / next-up notes — operator working notes,
# superseded by docs/steward-roadmap.md as the canonical roadmap.
/docs/next-up-*.md
/docs/*-pending-*.md

# Czech-language localisation drafts. Public docs ship in English
# (per ship-ready.md — i18n is NOT a v0 goal).
/docs/*.cs.md

